<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorHospitalBlue"
        android:orientation="vertical"
        android:paddingTop="40dp"
        android:paddingBottom="14dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_white_20"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="Back"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏥  Nearest Hospitals"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ಹತ್ತಿರದ ಆಸ್ಪತ್ರೆಗಳು — GPS + Offline data"
                    android:textColor="#CCffffff"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_location_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="📍 Locating you..."
            android:textColor="#CCffffff"
            android:textSize="12sp"/>

    </LinearLayout>

    <!-- Offline badge -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:background="@drawable/badge_offline_bg"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:text="📴  Offline mode — data cached locally"
        android:textColor="@color/colorWarning"
        android:textSize="11sp"
        android:textStyle="bold"/>

    <!-- Call 108 quick button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_ambulance"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        android:text="🚨  Call 108 — Ambulance"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="@color/colorPrimary"
        app:cornerRadius="12dp"/>

    <!-- Hospital list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_hospitals"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"
        android:overScrollMode="never"/>

</LinearLayout>
